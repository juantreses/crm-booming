{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "duration": {
            "type": "int",
            "required": true,
            "default": 60,
            "min": 5,
            "max": 1440,
            "isCustom": true
        },
        "minLeadTime": {
            "type": "int",
            "required": true,
            "default": 12,
            "min": 0,
            "max": 720,
            "isCustom": true,
            "tooltip": true
        },
        "maxBookingRange": {
            "type": "int",
            "required": true,
            "default": 30,
            "min": 1,
            "max": 730,
            "isCustom": true,
            "tooltip": true
        },
        "seatsPerMeeting": {
            "type": "int",
            "required": true,
            "default": 1,
            "min": 0,
            "max": 100,
            "isCustom": true
        },
        "priority": {
            "type": "int",
            "required": true,
            "default": 1,
            "min": 0,
            "max": 100,
            "isCustom": true,
            "tooltip": true
        },
        "bufferTime": {
            "type": "int",
            "default": 0,
            "min": 0,
            "max": 60,
            "isCustom": true,
            "tooltip": true
        },
        "isActive": {
            "notNull": true,
            "type": "bool",
            "isCustom": true,
            "default": true
        },
        "needsApproval": {
            "notNull": true,
            "type": "bool",
            "isCustom": true
        },
        "type": {
            "type": "enum",
            "options": [
                "kickstart",
                "bws",
                "spark",
                "hom",
                "workout",
                "coach",
                "event",
                "royalty",
                "online"
            ],
            "style": {
                "kickstart": null,
                "bws": null,
                "spark": null,
                "hom": null,
                "workout": null,
                "coach": null,
                "event": null,
                "royalty": null,
                "online": null
            },
            "default": "kickstart",
            "maxLength": 100,
            "isCustom": true,
            "required": true
        },
        "confirmationTemplate": {
            "type": "link"
        },
        "reminderTemplate": {
            "type": "link"
        },
        "location": {
            "type": "address",
            "isCustom": true
        },
        "slug": {
            "type": "varchar",
            "required": true,
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "isDirectBookable": {
            "notNull": true,
            "type": "bool",
            "tooltip": true,
            "isCustom": true
        },
        "cancellationTemplate": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "availabilities": {
            "type": "hasMany",
            "foreign": "calendar",
            "entity": "CAvailability",
            "audited": false,
            "isCustom": true
        },
        "meetings": {
            "type": "hasMany",
            "foreign": "cCalendar",
            "entity": "Meeting",
            "audited": false,
            "isCustom": true
        },
        "confirmationTemplate": {
            "type": "belongsTo",
            "foreign": "cCalendars",
            "entity": "EmailTemplate",
            "audited": false,
            "isCustom": true
        },
        "reminderTemplate": {
            "type": "belongsTo",
            "foreign": "cCalendars1",
            "entity": "EmailTemplate",
            "audited": false,
            "isCustom": true
        },
        "cTeams": {
            "type": "hasMany",
            "relationName": "cCalendarTeam",
            "foreign": "calendars",
            "entity": "CTeam",
            "audited": false,
            "isCustom": true
        },
        "cancellationTemplate": {
            "type": "belongsTo",
            "foreign": "cCalendars2",
            "entity": "EmailTemplate",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}