{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "type": {
            "type": "enum",
            "required": true,
            "options": [
                "recurrent",
                "specific"
            ],
            "style": {
                "recurrent": null,
                "specific": null
            },
            "default": "recurrent",
            "maxLength": 100,
            "isCustom": true
        },
        "daysOfWeek": {
            "type": "checklist",
            "storeArrayValues": true,
            "required": false,
            "default": [],
            "options": [
                "1",
                "2",
                "3",
                "4",
                "5",
                "6",
                "0"
            ],
            "isCustom": true
        },
        "startTime": {
            "type": "varchar",
            "required": true,
            "maxLength": 100,
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
            "default": "10:00",
            "options": [],
            "isCustom": true
        },
        "endTime": {
            "type": "varchar",
            "required": true,
            "maxLength": 100,
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
            "default": "17:00",
            "options": [],
            "isCustom": true
        },
        "date": {
            "notNull": false,
            "type": "date",
            "required": false,
            "default": null,
            "isCustom": true
        },
        "calendar": {
            "type": "link"
        },
        "location": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "calendar": {
            "type": "belongsTo",
            "foreign": "availabilities",
            "entity": "CCalendar",
            "audited": false,
            "isCustom": true
        },
        "location": {
            "type": "belongsTo",
            "foreign": "availabilities",
            "entity": "CLocation",
            "audited": false,
            "isCustom": true
        },
        "cTeams": {
            "type": "hasMany",
            "relationName": "cAvailabilityTeam",
            "foreign": "availabilities",
            "entity": "CTeam",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}