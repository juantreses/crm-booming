{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "vankoMeetingId": {
            "type": "varchar",
            "required": true,
            "maxLength": 100,
            "readOnlyAfterCreate": true,
            "options": [],
            "isCustom": true
        },
        "meetingType": {
            "type": "enum",
            "required": false,
            "options": [
                "KickStart",
                "Online Kickstart",
                "SPARK",
                "Beauty Workshop",
                "IOM",
                "Workout",
                "Interview",
                "Coach",
                "Royalty Gesprek"
            ],
            "style": {
                "KickStart": null,
                "Online Kickstart": null,
                "SPARK": null,
                "Beauty Workshop": null,
                "IOM": null,
                "Workout": null,
                "Interview": null,
                "Coach": null,
                "Royalty Gesprek": null
            },
            "default": "KickStart",
            "readOnlyAfterCreate": true,
            "maxLength": 100,
            "isCustom": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Planned",
                "Canceled"
            ],
            "style": {
                "Planned": null,
                "Canceled": null
            },
            "default": "Planned",
            "maxLength": 100,
            "isCustom": true
        },
        "lead": {
            "type": "link"
        },
        "calendarName": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "datum": {
            "notNull": false,
            "type": "datetime",
            "required": true,
            "minuteStep": 30,
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "lead": {
            "type": "belongsTo",
            "foreign": "cVankoAppointments",
            "entity": "Lead",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}