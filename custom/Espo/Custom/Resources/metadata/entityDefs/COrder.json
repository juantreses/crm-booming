{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "dateOrdered": {
            "notNull": false,
            "type": "date",
            "required": true,
            "default": "javascript: return this.dateTime.getToday();",
            "isCustom": true
        },
        "volumePoints": {
            "type": "int",
            "required": true,
            "isCustom": true
        },
        "products": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "programEnd": {
            "notNull": false,
            "type": "date",
            "required": true,
            "default": "javascript: return this.dateTime.getDateShiftedFromToday(3, 'weeks');",
            "isCustom": true
        },
        "contact": {
            "type": "link"
        },
        "programType": {
            "type": "enum",
            "options": [
                "21_day_base",
                "21_day_fit",
                "21_day_best_deal",
                "21_day_ultimate",
                "retail",
                "spark_free",
                "spark_10x",
                "pcx_15",
                "pcx_25",
                "pcx_35",
                "distributor"
            ],
            "style": {
                "21_day_base": null,
                "21_day_fit": null,
                "21_day_best_deal": null,
                "21_day_ultimate": null,
                "retail": null,
                "spark_free": null,
                "spark_10x": null,
                "pcx_15": null,
                "pcx_25": null,
                "pcx_35": null,
                "distributor": null
            },
            "default": "21_day_base",
            "maxLength": 100,
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "contact": {
            "type": "belongsTo",
            "foreign": "cOrders",
            "entity": "Contact",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}